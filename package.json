{
  "name": "visitor-access",
  "version": "2.0.2",
  "author": "lhy8888",
  "description": "Lightweight self-hosted visitor registration and reception check-in system for small offices.",
  "main": "server.js",
  "scripts": {
    "preinstall": "node scripts/check-runtime.js",
    "prestart": "node scripts/check-runtime.js",
    "start": "node server.js",
    "predev": "node scripts/check-runtime.js",
    "dev": "nodemon server.js",
    "electron:dev": "electron electron/main.js",
    "preinit": "node scripts/check-runtime.js",
    "init": "node scripts/init.js",
    "postinstall": "npm run init",
    "pretest": "node scripts/check-runtime.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "audit": "npm audit",
    "dist:win": "electron-builder --win nsis --publish never",
    "ubuntu:install": "bash scripts/ubuntu/install.sh",
    "ubuntu:update": "bash scripts/ubuntu/update.sh",
    "ubuntu:uninstall": "bash scripts/ubuntu/uninstall.sh"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "build": {
    "appId": "com.visit.access",
    "productName": "Visit Access",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      "scripts/check-runtime.js",
      "server.js",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ],
      "artifactName": "Visit-Access-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "perMachine": false
    }
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^4.19.2",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "multer": "^2.0.1",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.1",
    "winston": "^3.17.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "jsdom": "^26.1.0",
    "supertest": "^7.1.3"
  }
}
